{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/warmup",                                              "schedule": "*/2 * * * *"    },
    { "path": "/api/sales-metrics?period=today",                          "schedule": "*/2 * * * *"    },
    { "path": "/api/sales-metrics?period=week",                           "schedule": "*/2 * * * *"    },
    { "path": "/api/sales-pipeline",                                      "schedule": "*/2 * * * *"    },
    { "path": "/api/sales-calls",                                         "schedule": "*/2 * * * *"    },
    { "path": "/api/sales-metrics?period=lastweek",                       "schedule": "1-59/2 * * * *" },
    { "path": "/api/sales-metrics?period=month",                          "schedule": "1-59/2 * * * *" },
    { "path": "/api/sales-calls?period=week",                             "schedule": "1-59/2 * * * *" },
    { "path": "/api/sales-sources?period=month",                          "schedule": "1-59/2 * * * *" },
    { "path": "/api/sales-stage-conversion?mode=snapshot",                "schedule": "1-59/2 * * * *" },
    { "path": "/api/sales-stage-conversion?mode=cohort&period=month",     "schedule": "*/5 * * * *"    },
    { "path": "/api/sales-handoffs?period=month",                         "schedule": "2-59/5 * * * *" },
    { "path": "/api/sales-metrics?period=quarter",                        "schedule": "4-59/5 * * * *" },
    { "path": "/api/sales-rep-activity",                                  "schedule": "*/5 * * * *"    },
    { "path": "/api/installation-metrics",                                "schedule": "*/5 * * * *"    },
    { "path": "/api/sales-metrics?period=q1",                             "schedule": "*/10 * * * *"   },
    { "path": "/api/sales-metrics?period=q2",                             "schedule": "1-59/10 * * * *"},
    { "path": "/api/sales-metrics?period=q3",                             "schedule": "3-59/10 * * * *"},
    { "path": "/api/sales-metrics?period=q4",                             "schedule": "5-59/10 * * * *"}
  ]
}
